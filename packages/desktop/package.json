{
  "name": "@tesla-manager/desktop",
  "private": true,
  "version": "1.0.0",
  "main": "dist/main.cjs",
  "scripts": {
    "predev": "kill-port 5173",
    "dev": "concurrently --kill-others-on-fail -n CLIENT,BUILD,ELECTRON -c cyan,yellow,green \"yarn --cwd ../client dev --host\" \"tsup --watch\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electronmon dist/main.cjs\"",
    "build": "tsup",
    "dist": "electron-builder --config electron-builder.yml",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "electron": "^35.2.1",
    "electron-builder": "^26.0.12",
    "electronmon": "^2.0.3",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "wait-on": "^8.0.3"
  }
}
